<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>

    <!-- Package metadata -->
    <PackageId>Qwen3ASR.NET.Runtime.OSX-arm64</PackageId>
    <Description>Native runtime for Qwen3ASR.NET (macOS ARM64/Apple Silicon with Metal support)</Description>
    <PackageTags>speech-recognition;asr;qwen;ai;ml;transcription;native;runtime;metal</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- This package contains native binaries, not managed code -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <None Include="runtimes\**\*" Pack="true" PackagePath="runtimes" />
    <Content Include="runtimes\osx-arm64\native\libqwen3_asr_ffi.dylib" CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\..\README.md" Pack="true" PackagePath="" />
  </ItemGroup>

</Project>
